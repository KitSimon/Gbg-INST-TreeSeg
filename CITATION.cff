license: AGPL-3.0-or-later
repository-code: "https://github.com/KitSimon/Gbg-INST-TreeSeg"
year: 2026
keywords:
  - tree crown delineation
  - instance segmentation
  - remote sensing
  - Cellpose
  - GeoAI
references:
